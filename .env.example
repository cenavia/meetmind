# URL base de la API (usado por la UI Gradio)
API_BASE_URL=http://localhost:8000

# --- Transcripción multimedia (Whisper) ---
# Backend: cloud = API OpenAI (whisper-1) | local = openai-whisper en tu máquina
# Si no defines TRANSCRIPTION_BACKEND: con OPENAI_API_KEY → cloud; sin clave → local
# TRANSCRIPTION_BACKEND=cloud
# OPENAI_API_KEY=sk-...
# Límite de la API cloud ~25 MB por archivo (ajustable en MB)
# OPENAI_TRANSCRIPTION_MAX_MB=25

# Solo modo local (openai-whisper + PyTorch):
# TRANSCRIPTION_MODEL=small
# TRANSCRIPTION_LANGUAGE=es
# WHISPER_DEVICE=auto

# ffmpeg solo extrae audio de video; el STT lo hace Whisper (API o local).

# Para futuras fases (LLM, persistencia)
# DATABASE_URL=sqlite:///./meetmind.db
